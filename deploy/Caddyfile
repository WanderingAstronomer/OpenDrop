# Caddy auto-provisions and renews TLS (Let's Encrypt) for $DOMAIN, redirects HTTP→HTTPS,
# sets HSTS, and reverse-proxies to the nginx `web` service.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	reverse_proxy web:80
}

# www → apex (Caddy still auto-provisions a cert for the www name so the redirect is served over TLS)
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
