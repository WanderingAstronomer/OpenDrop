# OpenDrop environment — copy to `.env` and adjust. All values below are dev-safe defaults.
#
# FORMAT CONTRACT (enforced by tests/test_env_contract.py): every comment is on its own line
# starting with `#` at column 0, and every KEY=VALUE line is bare — no trailing inline `# comment`.
# This keeps the file safe to load through EVERY path: `docker run --env-file` and some compose
# versions take the text after `=` LITERALLY, so a trailing comment would be swallowed into the
# value (e.g. POINT_CAP would become "2000   # >this many..." and fail int parsing at boot).

# --- Database ---
POSTGRES_USER=opendrop
POSTGRES_PASSWORD=opendrop
POSTGRES_DB=opendrop
DATABASE_URL=postgresql://opendrop:opendrop@db:5432/opendrop

# --- Ports (host) ---
API_PORT=8000
# open the map at http://localhost:8080
WEB_PORT=8080

# --- API ---
# no-op in the same-origin nginx setup; for split-origin dev only
CORS_ORIGINS=http://localhost:8080
# salts the per-IP vote-cooldown hash (never stores raw IPs)
IP_HASH_SALT=change-me-in-prod
SUBMIT_PER_IP_PER_DAY=10
# >this many points in bbox => server returns clusters (national-safe; raise for denser point
# views, costs browser perf)
POINT_CAP=2000
# max cluster cells returned; ~enough to tile a national bbox at the 1/32 cell size
CLUSTER_CAP=400

# --- Community photos ---
# where uploaded (EXIF-stripped) photos are written
MEDIA_DIR=/app/media
# reject uploads larger than ~6 MB (413)
IMAGE_MAX_BYTES=6000000
# per-IP daily photo-upload cap
IMAGE_UPLOADS_PER_IP_PER_DAY=8
# global media disk ceiling (~5 GB); uploads past it return 507
MEDIA_MAX_TOTAL_BYTES=5000000000

# --- Moderation & abuse controls ---
# EMPTY => all /api/admin/* endpoints 404 (feature off, surface hidden). Set a long random secret
# to enable takedown/restore/revert; the operator sends it as the `X-Operator-Token` header.
# Compared in constant time.
OPERATOR_TOKEN=
# extra comma-separated words rejected in submissions/reports, MERGED with the baked-in default
# denylist (operators extend, never replace)
CONTENT_DENYLIST=
# per-IP daily cap shared across location + photo reports
REPORTS_PER_IP_PER_DAY=30
# distinct unresolved reporters to soft-hide a PHOTO (reversible; file kept). A lone report only
# files a complaint. Locations are NEVER auto-hidden.
REPORT_IMAGE_HIDE_THRESHOLD=2
# hard cap on rows returned by the full-dataset /api/export dump
EXPORT_MAX_ROWS=100000

# --- Schema/version guard ---
# The migration this image's code requires is pinned IN THE IMAGE (backend/app/config.py,
# `expected_schema_version`). At boot, prod REFUSES to start unless that row is present in
# schema_migrations — this is what blocks 'new code vs old schema' drift (the corrections-500 bug).
# Do NOT set EXPECTED_SCHEMA_VERSION here: a hand-pinned value in .env silently overrides the
# image's own value and WILL drift behind it on the next migration, re-arming the exact drift the
# guard exists to prevent. Leave it to the image. (Both rules enforced by tests/test_env_contract.py.)

# --- Community pin corrections + signals ---
# Engagement tiers (Cold <3 / Warm 3-14 / Hot 15+ distinct contributions) and the support
# thresholds they gate are baked into the SQL consensus functions (migrations 0006/0007), not
# env-tunable. These four knobs are:
# per-IP daily cap on proposing pin corrections
CORRECTIONS_PER_IP_PER_DAY=15
# per-IP daily cap on NEW (location, attribute) ratings
ATTRIBUTES_PER_IP_PER_DAY=60
# a fix may move a pin at most 2 km from its ORIGIN (anchored in 0007, enforced by API + trigger)
CORRECTION_MAX_MOVE_M=2000
# client-side "I'm standing here" radius; server only ever sees the resulting yes/no, never coords
GPS_CORROBORATION_RADIUS_M=75

# --- Cloudflare Turnstile (dev mock = always-passes test keys) ---
# CF "always passes" TEST secret (dev mock mode)
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
# CF test sitekey (renders a passing widget)
TURNSTILE_SITEKEY=1x00000000000000000000AA

# --- External services (batch / submit only) ---
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org/search

# --- Scraper politeness (batch ingest only; read straight from the environment by the pipeline) ---
# Every scraper request paces + backs off so a long sweep stays a good citizen. Raise the delay to
# be gentler / run longer; the whole job is roughly delay x request-count. Backoff/Retry-After are
# honored automatically on 429 + 5xx. (Nominatim is pinned to 1 req/s internally per its ToS.)
# min seconds between requests per scraper client
SCRAPER_REQUEST_DELAY_S=0.5
# retries on 429/5xx/network error before skipping that item
SCRAPER_MAX_RETRIES=4
# exponential backoff base (2s, 4s, 8s, ... + jitter)
SCRAPER_BACKOFF_BASE_S=2.0
# max single backoff wait
SCRAPER_BACKOFF_CAP_S=60.0
# split a region bbox into <=this-degree tiles for Overpass (smaller = more, lighter queries)
OSM_TILE_DEGREES=3.0

# --- Seed region (pick a named region from pipeline/regions.py) ---
# Curated:  columbus (default) | ohio (statewide) | greater_ohio (OH + MI/IN/KY/WV/PA)
# National: usa (all 50 states + DC as one region) | any 2-letter state code (ca, tx, ny, ...) or
#           full state name (california, "new york"). Per-state/usa regions are data-driven from
#           pipeline/data/us_zips.csv. An unknown value falls back to columbus.
REGION=columbus
# overrides the bbox of the 'columbus' region ONLY (ignored for ohio/greater_ohio/national)
SEED_REGION_BBOX=39.80,-83.25,40.18,-82.75
# scheduler re-sync cadence (24h)
SYNC_INTERVAL_SECONDS=86400

# --- National seed (pipeline/seed_national.py — the gentle, resumable, overnight all-US sweep) ---
# Run with:  bash scripts/seed_national.sh   (or: docker compose run --rm api python -m pipeline.seed_national)
# It walks all 50 states + DC, checkpointing each in the seed_progress table (migration 0008), so an
# interrupted run resumes where it left off on re-run. Pace it with SCRAPER_REQUEST_DELAY_S above.
# set to 1 to ignore checkpoints and re-seed every state from scratch
SEED_FORCE=

# --- Closure detection (reconciliation circuit breaker) ---
# A re-sync retires source links it no longer sees upstream. These guard against a truncated/
# blocked upstream response mass-deleting a region; raise/lower for a deliberate operator re-sync.
# skip closure-detection if a run saw fewer records
RECONCILE_MIN_SEEN=5
# skip if a run would retire >40% of a source's in-region links
RECONCILE_MAX_FRACTION=0.40

# --- Production guard (set APP_ENV=prod to refuse boot with default secrets) ---
APP_ENV=dev

# --- Production TLS (used only by docker-compose.prod.yml / Caddy) ---
DOMAIN=opendrop.example.org
ACME_EMAIL=admin@example.org
