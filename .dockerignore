# Keep the api build context lean and secret-free (build context is the repo root).
.git
.gitignore
.gitattributes
.dockerignore
.env
.env.*
!.env.example
.claude/

# Caches / volumes / build junk
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
pgdata/
node_modules/
*.log

# Docs / tests not needed at runtime
*.md
tests/
backend/tests/

# The api image doesn't serve the frontend (nginx does, via a volume mount)
frontend/
