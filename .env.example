# OpenDrop environment — copy to `.env` and adjust. All values below are dev-safe defaults.

# --- Database ---
POSTGRES_USER=opendrop
POSTGRES_PASSWORD=opendrop
POSTGRES_DB=opendrop
DATABASE_URL=postgresql://opendrop:opendrop@db:5432/opendrop

# --- Ports (host) ---
API_PORT=8000
WEB_PORT=8080                                         # open the map at http://localhost:8080

# --- API ---
CORS_ORIGINS=http://localhost:8080                    # no-op in the same-origin nginx setup; for split-origin dev only
IP_HASH_SALT=change-me-in-prod                        # salts the per-IP vote-cooldown hash (never stores raw IPs)
SUBMIT_PER_IP_PER_DAY=10
POINT_CAP=2000                                        # >this many points in bbox => server returns clusters (national-safe; raise for denser point views, costs browser perf)
CLUSTER_CAP=400                                        # max cluster cells returned; ~enough to tile a national bbox at the 1/32 cell size

# --- Community photos ---
MEDIA_DIR=/app/media                                  # where uploaded (EXIF-stripped) photos are written
IMAGE_MAX_BYTES=6000000                               # reject uploads larger than ~6 MB (413)
IMAGE_UPLOADS_PER_IP_PER_DAY=8                        # per-IP daily photo-upload cap
MEDIA_MAX_TOTAL_BYTES=5000000000                      # global media disk ceiling (~5 GB); uploads past it return 507

# --- Moderation & abuse controls ---
OPERATOR_TOKEN=                                       # EMPTY => all /api/admin/* endpoints 404 (feature off, surface hidden).
                                                      # Set a long random secret to enable takedown/restore/revert; the operator
                                                      # sends it as the `X-Operator-Token` header. Compared in constant time.
CONTENT_DENYLIST=                                     # extra comma-separated words rejected in submissions/reports, MERGED with
                                                      # the baked-in default denylist (operators extend, never replace)
REPORTS_PER_IP_PER_DAY=30                             # per-IP daily cap shared across location + photo reports
REPORT_IMAGE_HIDE_THRESHOLD=2                         # distinct unresolved reporters to soft-hide a PHOTO (reversible; file kept).
                                                      # A lone report only files a complaint. Locations are NEVER auto-hidden.
EXPORT_MAX_ROWS=100000                                # hard cap on rows returned by the full-dataset /api/export dump

# --- Schema/version guard ---
EXPECTED_SCHEMA_VERSION=0010_moderation_audit_and_thresholds.sql  # in prod the API REFUSES to boot if this migration row is
                                                      # absent from schema_migrations (blocks 'new code vs old schema' drift)

# --- Community pin corrections + signals ---
# Engagement tiers (Cold <3 / Warm 3-14 / Hot 15+ distinct contributions) and the support
# thresholds they gate are baked into the SQL consensus functions (migrations 0006/0007), not
# env-tunable. These four knobs are:
CORRECTIONS_PER_IP_PER_DAY=15                         # per-IP daily cap on proposing pin corrections
ATTRIBUTES_PER_IP_PER_DAY=60                          # per-IP daily cap on NEW (location, attribute) ratings
CORRECTION_MAX_MOVE_M=2000                            # a fix may move a pin at most 2 km from its ORIGIN (anchored in 0007, enforced by API + trigger)
GPS_CORROBORATION_RADIUS_M=75                         # client-side "I'm standing here" radius; server only ever sees the resulting yes/no, never coordinates

# --- Cloudflare Turnstile (dev mock = always-passes test keys) ---
TURNSTILE_SECRET=1x0000000000000000000000000000000AA  # CF "always passes" TEST secret (dev mock mode)
TURNSTILE_SITEKEY=1x00000000000000000000AA            # CF test sitekey (renders a passing widget)

# --- External services (batch / submit only) ---
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org/search

# --- Scraper politeness (batch ingest only; read straight from the environment by the pipeline) ---
# Every scraper request paces + backs off so a long sweep stays a good citizen. Raise the delay to
# be gentler / run longer; the whole job is roughly delay x request-count. Backoff/Retry-After are
# honored automatically on 429 + 5xx. (Nominatim is pinned to 1 req/s internally per its ToS.)
SCRAPER_REQUEST_DELAY_S=0.5                            # min seconds between requests per scraper client
SCRAPER_MAX_RETRIES=4                                  # retries on 429/5xx/network error before skipping that item
SCRAPER_BACKOFF_BASE_S=2.0                             # exponential backoff base (2s, 4s, 8s, ... + jitter)
SCRAPER_BACKOFF_CAP_S=60.0                             # max single backoff wait
OSM_TILE_DEGREES=3.0                                   # split a region bbox into <=this-degree tiles for Overpass (smaller = more, lighter queries)

# --- Seed region (pick a named region from pipeline/regions.py) ---
# Curated:  columbus (default) | ohio (statewide) | greater_ohio (OH + MI/IN/KY/WV/PA)
# National: usa (all 50 states + DC as one region) | any 2-letter state code (ca, tx, ny, ...) or
#           full state name (california, "new york"). Per-state/usa regions are data-driven from
#           pipeline/data/us_zips.csv. An unknown value falls back to columbus.
REGION=columbus
SEED_REGION_BBOX=39.80,-83.25,40.18,-82.75            # overrides the bbox of the 'columbus' region ONLY (ignored for ohio/greater_ohio/national)
SYNC_INTERVAL_SECONDS=86400                           # scheduler re-sync cadence (24h)

# --- National seed (pipeline/seed_national.py — the gentle, resumable, overnight all-US sweep) ---
# Run with:  bash scripts/seed_national.sh   (or: docker compose run --rm api python -m pipeline.seed_national)
# It walks all 50 states + DC, checkpointing each in the seed_progress table (migration 0008), so an
# interrupted run resumes where it left off on re-run. Pace it with SCRAPER_REQUEST_DELAY_S above.
SEED_FORCE=                                            # set to 1 to ignore checkpoints and re-seed every state from scratch

# --- Closure detection (reconciliation circuit breaker) ---
# A re-sync retires source links it no longer sees upstream. These guard against a truncated/
# blocked upstream response mass-deleting a region; raise/lower for a deliberate operator re-sync.
RECONCILE_MIN_SEEN=5                                   # skip closure-detection if a run saw fewer records
RECONCILE_MAX_FRACTION=0.40                            # skip if a run would retire >40% of a source's in-region links

# --- Production guard (set APP_ENV=prod to refuse boot with default secrets) ---
APP_ENV=dev

# --- Production TLS (used only by docker-compose.prod.yml / Caddy) ---
DOMAIN=opendrop.example.org
ACME_EMAIL=admin@example.org
